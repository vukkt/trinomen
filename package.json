{
  "name": "trinomen",
  "version": "0.1.3",
  "description": "Three-agent LLM pipeline in your terminal: a router classifies the prompt, a worker generates, a reviewer audits — all on free Groq + Gemini tiers with local budget tracking",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vukkt/trinomen.git"
  },
  "homepage": "https://github.com/vukkt/trinomen#readme",
  "bugs": {
    "url": "https://github.com/vukkt/trinomen/issues"
  },
  "type": "module",
  "bin": {
    "trinomen": "bin/cli.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "dev": "node --watch bin/cli.js",
    "test": "npm run test:unit && npm run test:eval",
    "test:unit": "node --test test/unit.test.js",
    "test:eval": "node test/eval.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "cli",
    "ai",
    "agents",
    "llm",
    "gemini",
    "groq",
    "orchestration",
    "code-review",
    "multi-agent",
    "rate-limit"
  ],
  "author": "Vuk Topalovic <vuk.topalovic@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/groq": "^3.0.39",
    "@inquirer/prompts": "^8.5.2",
    "ai": "^6.0.199",
    "better-sqlite3": "^11.3.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "zod": "^4.4.3"
  }
}
